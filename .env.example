# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings -> API). .env.local is NOT committed.
#
# Without these the site still runs, but the suggestion form shows a
# "form not connected to the database" message.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public address of the site (no trailing slash). Used by metadata,
# sitemap.xml, robots.txt and the social-share image. On Vercel it is
# auto-detected from the deployment's production domain, so you only need to
# set this for a custom domain (or non-Vercel hosting). Local default:
# http://localhost:3000.
NEXT_PUBLIC_SITE_URL=
